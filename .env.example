# Copiar a .env:  copy .env.example .env   luego:  php artisan key:generate
# Sitio estático: sin base de datos en uso (caché file, cola sync, sesión file).

APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Solo si más adelante añades BD (opcional):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# ...
