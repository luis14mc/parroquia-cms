# Copiar a .env. En Railway: Reference al servicio MySQL (variables inyectadas).

APP_KEY=
APP_ENV=local
APP_URL=http://localhost:8000
DB_CONNECTION=mysql
SESSION_DRIVER=file

# ── MySQL (Railway: URL interna; app y BD en el mismo proyecto) ───────────────
# Host interno solo accesible desde el contenedor en Railway, no desde tu PC local.
MYSQL_URL="mysql://USER:PASSWORD@mysql.railway.internal:3306/railway"
MYSQLDATABASE="railway"
MYSQLHOST="mysql.railway.internal"
MYSQLPASSWORD=""
MYSQLPORT="3306"
MYSQLUSER="root"
