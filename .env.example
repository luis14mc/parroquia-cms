# Copiar a .env:  copy .env.example .env   luego:  php artisan key:generate
# Sitio estático: la base solo hace falta si más adelante usas login u otras tablas Laravel.

APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
SESSION_DRIVER=file

# MySQL local (XAMPP) o Railway (Reference al plugin MySQL)
MYSQLHOST=127.0.0.1
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQL_DATABASE=laravel

# Opcional: URL única (Railway suele inyectar MYSQL_URL)
# MYSQL_URL=

# ══ Railway (producción) ══
# APP_ENV=production, APP_DEBUG=false, APP_URL=https://tu-dominio
# Referencia MySQL: MYSQL_URL, MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQL_DATABASE
# RAILPACK_PHP_EXTENSIONS=intl,pdo_mysql

# Tests: phpunit.xml usa SQLite en memoria; ver también .env.testing
