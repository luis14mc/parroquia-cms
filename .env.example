# ── LOCAL (este archivo se copia a .env; NO se sube a Git; Railway NO lee tu .env de la PC) ──
# En producción debes repetir las mismas claves en Railway → tu servicio WEB → Variables:
# "Add variable" → Reference → MySQL → MYSQL_URL, MYSQLHOST, MYSQLDATABASE, etc.
# El host mysql.railway.internal solo existe DENTRO de la red de Railway, no desde tu ordenador.

# Copiar a .env para desarrollo local.
# Requisito PHP local: pdo_mysql, intl y zip (Filament / export CSV). Ej.: sudo apt install php8.3-{mysql,intl,zip}; php -m | egrep 'pdo_mysql|intl|zip'

APP_KEY=
APP_ENV=local
APP_URL=http://localhost:8000
DB_CONNECTION=mysql
SESSION_DRIVER=file

# ── Conexión por URL (recomendado en Railway; Laravel prioriza la URL sobre host/puerto sueltos)
# En el servicio WEB: referencia MYSQL_URL desde MySQL. Si DATABASE_URL es de Postgres, no se usa para mysql.
# MySQL (plugin Railway): suelen inyectarse al referenciar el servicio
# MYSQL_URL=mysql://USER:PASSWORD@mysql.railway.internal:3306/railway
# Postgres: Railway suele usar esta (y DB_CONNECTION=pgsql)
# DATABASE_URL=postgresql://USER:PASSWORD@host:5432/railway
# Alias genérico Laravel 11+:
# DB_URL=...

# ── MySQL sin URL (o como respaldo si la URL no está)
# Railway a veces nombra la base MYSQL_DATABASE; Laravel acepta MYSQLDATABASE o MYSQL_DATABASE.
#
# Desde tu PC: MySQL en Railway expone un proxy TCP (host tipo *.proxy.rlwy.net y puerto distinto de 3306).
# En el servicio web en Railway: suele usarse el host interno mysql.railway.internal:3306 (Reference al plugin).
MYSQLDATABASE="railway"
MYSQL_DATABASE="railway"
MYSQLHOST="mysql.railway.internal"
MYSQLPASSWORD=""
MYSQL_ROOT_PASSWORD=""
MYSQLPORT="3306"
MYSQLUSER="root"

CMS_ADMIN_EMAIL=
CMS_ADMIN_PASSWORD=
CMS_SUBMISSION_NOTIFY_EMAILS=

# ══ PRODUCCIÓN (servicio WEB en Railway) — checklist rápido ══
# 1) Mismo proyecto: servicio MySQL + servicio Web. En WEB → Variables → "Reference" al MySQL:
#    MYSQL_URL, MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE (o MYSQL_DATABASE).
# 2) Nunca pegues aquí el host del TCP proxy (*.proxy.rlwy.net); en el contenedor usa mysql.railway.internal (viene en Reference).
# 3) APP_KEY=(php artisan key:generate --show), APP_ENV=production, APP_DEBUG=false, APP_URL=https://TU_DOMINIO
# 4) Opcional: LOG_CHANNEL=stderr para ver errores en los logs de Railway.
# 5) PHP: extensiones intl + zip + pdo_mysql (Railway Railpack): RAILPACK_PHP_EXTENSIONS=intl,zip,pdo_mysql
# 6) El repo incluye railway.json → fuerza migrate + serve al arrancar (sobrescribe el start por defecto de Railpack).

# ── Tests (phpunit.xml): MySQL obligatorio, no SQLite
# Base local: crear "testing" y usuario root con la contraseña de phpunit.xml, o:
# docker run -d --name mysql-test -e MYSQL_ROOT_PASSWORD=password -e MYSQL_DATABASE=testing -p 3306:3306 mysql:8.4
