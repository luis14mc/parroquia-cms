# Copiar a .env:  copy .env.example .env   luego:  php artisan key:generate
# Sitio estático: sin MySQL ni migraciones en Railway.

APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Laravel requiere una conexión por defecto; SQLite en memoria no usa servidor ni archivo.
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
