# Copiar a .env. En Railway: Variables → Reference al servicio de base de datos.

APP_KEY=
APP_ENV=local
APP_URL=http://localhost:8000
DB_CONNECTION=mysql
SESSION_DRIVER=file

# ── Conexión por URL (recomendado en Railway; Laravel prioriza la URL sobre host/puerto sueltos)
# MySQL (plugin Railway): suelen inyectarse al referenciar el servicio
# MYSQL_URL=mysql://USER:PASSWORD@mysql.railway.internal:3306/railway
# Postgres: Railway suele usar esta (y DB_CONNECTION=pgsql)
# DATABASE_URL=postgresql://USER:PASSWORD@host:5432/railway
# Alias genérico Laravel 11+:
# DB_URL=...

# ── MySQL sin URL (o como respaldo si la URL no está)
MYSQLDATABASE="railway"
MYSQLHOST="mysql.railway.internal"
MYSQLPASSWORD=""
MYSQLPORT="3306"
MYSQLUSER="root"

# ── Producción Railway (checklist)
# - Mismo proyecto: app y BD comparten red; host interno *.railway.internal solo existe EN EL CONTENEDOR.
# - Desde tu PC, mysql.railway.internal NO resuelve: prueba en deploy o Railway Shell.
# - Tras cambiar variables: php artisan optimize:clear && php artisan migrate --force
# - DB_CONNECTION debe coincidir con el motor (mysql vs pgsql) y con la URL referenciada.
