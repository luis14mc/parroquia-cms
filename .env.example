# Railway: el servicio WEB debe tener referencia al MySQL (Variables → Reference → MYSQL_URL / MYSQLHOST…).
# Si no hay MYSQL_* en el servicio web, Laravel usa SQLite y los datos NO van al MySQL del proyecto.
#
# Laravel (APP_KEY, APP_URL, SESSION_DRIVER=file). Opcional: DB_CONNECTION=mysql (por defecto ya es mysql si existe MYSQL_*).
# No definas DB_URL ni DB_HOST manual si usas MYSQL_URL (URL interna).
APP_KEY=
APP_ENV=local
APP_URL=http://localhost:8000
DB_CONNECTION=mysql
SESSION_DRIVER=file

MYSQL_DATABASE="railway"
MYSQL_PUBLIC_URL="mysql://root:iNKrzGODuVzHhwOsJLWSfvmMvJROfLWl@ballast.proxy.rlwy.net:23116/railway"
MYSQL_ROOT_PASSWORD="iNKrzGODuVzHhwOsJLWSfvmMvJROfLWl"
# En producción (Railway, app + MySQL en el mismo proyecto): usar esta URL interna — la usa config/database.php con prioridad
MYSQL_URL="mysql://root:iNKrzGODuVzHhwOsJLWSfvmMvJROfLWl@mysql.railway.internal:3306/railway"
MYSQLDATABASE="railway"
MYSQLHOST="mysql.railway.internal"
MYSQLPASSWORD="iNKrzGODuVzHhwOsJLWSfvmMvJROfLWl"
MYSQLPORT="3306"
MYSQLUSER="root"