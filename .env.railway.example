# ============================================
# Variables de entorno para Railway
# Copia estas variables en el panel de Railway
# ============================================

# --- Aplicación (OBLIGATORIAS) ---
APP_NAME="Parroquia Cristo Resucitado"
APP_ENV=production
APP_DEBUG=false
# Railway inyecta RAILWAY_PUBLIC_DOMAIN; usa: https://${{RAILWAY_PUBLIC_DOMAIN}}
APP_URL=https://tu-app.up.railway.app

# Generar con: php artisan key:generate --show
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# --- Base de datos (Railway las inyecta automáticamente con PostgreSQL) ---
# Si añades PostgreSQL, Railway crea DATABASE_URL automáticamente
DB_CONNECTION=pgsql
# DATABASE_URL se inyecta automáticamente por Railway

# --- Cache y sesiones (usar database en producción) ---
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# --- Archivos (Railway: disco efímero, considerar S3 para uploads) ---
FILESYSTEM_DISK=local

# --- Logs ---
LOG_CHANNEL=stderr
LOG_LEVEL=warning
